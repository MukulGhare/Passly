# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# Database
DB_USERNAME=passly_user
DB_PASSWORD=passly_pass

# JWT — generate a secure 256-bit secret for production
# Example: openssl rand -hex 32
JWT_SECRET=change-me

# Spring Profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# Cloudinary — get these from cloudinary.com > Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS — comma-separated list of allowed origins (required in prod)
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
